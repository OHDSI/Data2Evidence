{
  "name": "@ohdsi/d2e",
  "version": "0.10.0",
  "description": "Data2Evidence Installer",
  "license": "Apache-2.0",
  "homepage": "https://d2e.sg",
  "repository": {
    "type": "git",
    "url": "https://github.com/ohdsi/d2e.git"
  },
  "bugs": "https://github.com/ohdsi/d2e/issues",
  "bin": {
    "d2e": "scripts/cli.sh"
  },
  "config": {
    "env_names_all": "local remote base-all base-local base-remote alp-dev-sg-3 alp-dev-sg-2 alp-stg-de-1 alp-stg-sg-1 alp-stg-sg-2",
    "env_names_dev": "local remote base-all base-local base-remote alp-dev-sg-3"
  },
  "scripts": {
    "init": "cross-env PROJECT_NAME=alp ENV_TYPE=local ./scripts/cli.sh --version develop --env-file .env.local init",
    "inithana": "cross-env PROJECT_NAME=alp ENV_TYPE=local ./scripts/cli.sh --version develop --env-file .env.local inithana",
    "local": "cross-env PROJECT_NAME=alp ENV_TYPE=local CADDY__CONFIG=./deploy/caddy-config ./scripts/cli.sh --version develop --demo --env-file .env.local --function-path ./functions -p 41100",
    "build": "npm run local -- build",
    "start": "npm run local -- start",
    "stop": "npm run local -- stop",
    "clean": "npm run local -- cleanci",
    "config": "npm run local -- config",
    "ps": "npm run local -- status",
    "ci:logs": "npm run local -- logs",
    "setup": "npm run local -- setupdemo",
    "deploy:logs": "cross-env ENV_TYPE=remote ./scripts/cli.sh -v develop -e -n .env.remote logs",
    "logs": "npm run local -- logs",
    "create-postgres-cdm-schemas": "bash scripts/create-cdm-schema.sh",
    "inittestdb": "node tests/backend_integration_tests/build/initdb.js test",
    "removetestdb": "node tests/backend_integration_tests/build/initdb.js rmonly",
    "internal": "npm run-script --prefix internal",
    "build:ts": "tsc ./scripts/cli.ts --outDir ./scripts/dist",
    "prepare": "npm run build:ts"
  },
  "optionalDependencies": {
    "hdb": "0.19.12",
    "fast-csv": "5.0.2"
  },
  "devDependencies": {
    "@types/node": "^18",
    "ts-node": "10.9.2",
    "yarn": "1.22.10"
  },
  "dependencies": {
    "commander": "^10.0.1",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.7",
    "zx": "^8.3.2"
  }
}
