            "text": "{\"data\":[{\"patient.attributes.pcount\":116352}],\"sql\":\"WITH PatientRequest0 AS (SELECT P0.\\\"person_id\\\" AS \\\"patient.attributes.pcount.0\\\", P0.\\\"person_id\\\" AS \\\"patient.attributes.pid\\\" FROM alpdev_pg.cdm01409d9210644f64ab1d96b010df5818.\\\"person\\\" P0 GROUP BY P0.\\\"person_id\\\", P0.\\\"person_id\\\") , MeasurePopulation AS (SELECT COUNT(DISTINCT(PatientRequest0.\\\"patient.attributes.pcount.0\\\")) AS \\\"patient.attributes.pcount\\\" , PatientRequest0.\\\"patient.attributes.pid\\\" AS \\\"patient.attributes.pid\\\" ,COUNT(1) over(partition by CURRENT_USER ) as \\\"gr_cnt\\\" FROM PatientRequest0 GROUP BY PatientRequest0.\\\"patient.attributes.pid\\\") , TotalPatientCount AS (SELECT COUNT(distinct MeasurePopulation.\\\"patient.attributes.pid\\\") as \\\"patient.attributes.pcount\\\" FROM MeasurePopulation WHERE MeasurePopulation.\\\"gr_cnt\\\" >= 1 ) SELECT * FROM TotalPatientCount\",\"sqlParameters\":[],\"debug\":{\"FAST\":{\"statement\":{\"def\":[{\"name\":\"PatientRequest0\",\"context\":\"patient\",\"accessLevel\":\"Public\",\"expression\":{\"type\":\"Query\",\"actionType\":\"totalpcount\",\"source\":[{\"alias\":\"P0\",\"expression\":{\"type\":\"Retrieve\",\"dataType\":\"patient\",\"templateId\":\"patient\"}}],\"groupBy\":[{\"type\":\"Property\",\"path\":\"pcount\",\"scope\":\"P0\",\"alias\":\"patient.attributes.pcount\"},{\"type\":\"Property\",\"path\":\"pid\",\"scope\":\"P0\",\"alias\":\"patient.attributes.pid\",\"axis\":\"y\"}]}},{\"name\":\"MeasurePopulation\",\"context\":\"population\",\"accessLevel\":\"Public\",\"expression\":{\"type\":\"AggregateExpression\",\"actionType\":\"totalpcount\",\"source\":[{\"name\":\"PatientRequest0\",\"type\":\"ExpressionRef\"}],\"groupBy\":[{\"type\":\"Property\",\"path\":\"patient.attributes.pid\",\"scope\":\"PatientRequest0\",\"alias\":\"patient.attributes.pid\",\"axis\":\"y\",\"templateId\":\"patient-attributes-pid\"}],\"measure\":[{\"type\":\"Property\",\"path\":\"patient.attributes.pcount\",\"scope\":\"PatientRequest0\",\"alias\":\"patient.attributes.pcount\",\"templateId\":\"patient-attributes-pcount\"}]}}]}},\"sql\":\"WITH  PatientRequest0 AS (SELECT P0.\\\"person_id\\\" AS \\\"patient.attributes.pcount.0\\\", P0.\\\"person_id\\\" AS \\\"patient.attributes.pid\\\"  FROM $$SCHEMA$$.\\\"person\\\" P0  GROUP BY P0.\\\"person_id\\\", P0.\\\"person_id\\\") ,  MeasurePopulation AS (SELECT COUNT(DISTINCT(PatientRequest0.\\\"patient.attributes.pcount.0\\\")) AS \\\"patient.attributes.pcount\\\" , PatientRequest0.\\\"patient.attributes.pid\\\" AS \\\"patient.attributes.pid\\\" ,COUNT(1) over(partition by CURRENT_USER )  as \\\"gr_cnt\\\"  FROM  PatientRequest0   GROUP BY PatientRequest0.\\\"patient.attributes.pid\\\")  , TotalPatientCount AS (SELECT COUNT(distinct MeasurePopulation.\\\"patient.attributes.pid\\\")  as \\\"patient.attributes.pcount\\\"  FROM MeasurePopulation  WHERE MeasurePopulation.\\\"gr_cnt\\\" >= 1 )  SELECT * FROM TotalPatientCount\",\"params\":[]}}"
