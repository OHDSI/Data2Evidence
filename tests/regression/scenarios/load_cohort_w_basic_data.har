            "text": "{\"data\":[{\"totalpcount\":60014,\"patient.attributes.pcount\":60014,\"patient.attributes.Gender_concept_name\":\"FEMALE\"}],\"sql\":\"WITH PatientRequest0 AS (SELECT COALESCE(P0concept___REFconceptidPATIENTgenderconceptid.concept_name, 'No matching concept') AS \\\"patient.attributes.Gender_concept_name\\\", P0.\\\"person_id\\\" AS \\\"patient.attributes.pcount.0\\\", P0.\\\"person_id\\\" AS \\\"patient.attributes.pid\\\" FROM alpdev_pg.cdm01409d9210644f64ab1d96b010df5818.\\\"person\\\" P0 LEFT JOIN alpdev_pg.cdmvocab.\\\"concept\\\" P0concept___REFconceptidPATIENTgenderconceptid ON (1=1 AND P0concept___REFconceptidPATIENTgenderconceptid.concept_id = P0.gender_concept_id) WHERE ((date_part('year', current_date) - P0.\\\"YEAR_OF_BIRTH\\\" > 70) AND (UPPER(COALESCE(P0concept___REFconceptidPATIENTgenderconceptid.concept_name, 'No matching concept')) = UPPER('FEMALE'))) GROUP BY COALESCE(P0concept___REFconceptidPATIENTgenderconceptid.concept_name, 'No matching concept'), P0.\\\"person_id\\\", P0.\\\"person_id\\\") , PatientCount AS (SELECT COUNT(DISTINCT(PatientRequest0.\\\"patient.attributes.pcount.0\\\")) AS \\\"patient.attributes.pcount\\\" , PatientRequest0.\\\"patient.attributes.pid\\\" AS \\\"patient.attributes.pid\\\" ,COUNT(1) over(partition by PatientRequest0.\\\"patient.attributes.Gender_concept_name\\\" ) as \\\"gr_cnt\\\" FROM PatientRequest0 GROUP BY PatientRequest0.\\\"patient.attributes.Gender_concept_name\\\", PatientRequest0.\\\"patient.attributes.pid\\\") , MeasurePopulation AS (SELECT COUNT(DISTINCT(PatientRequest0.\\\"patient.attributes.pcount.0\\\")) AS \\\"patient.attributes.pcount\\\" , PatientRequest0.\\\"patient.attributes.Gender_concept_name\\\" AS \\\"patient.attributes.Gender_concept_name\\\" FROM PatientRequest0 GROUP BY PatientRequest0.\\\"patient.attributes.Gender_concept_name\\\" HAVING (COUNT(DISTINCT(PatientRequest0.\\\"patient.attributes.pcount.0\\\")) >= 1) ORDER BY PatientRequest0.\\\"patient.attributes.Gender_