{
  "workspace": [],
  "nodeModulesDir": "auto",
  "imports": {
    "express": "npm:express",
    "http-proxy-middleware": "npm:http-proxy-middleware"
  },
  "tasks": {
    "start": "deno run --allow-all index.ts",
    "dev": "deno run --allow-all --watch index.ts"
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "singleQuote": true
  },
  "compilerOptions": {
    "allowJs": true,
    "lib": ["deno.window"],
    "strict": true
  }
}
