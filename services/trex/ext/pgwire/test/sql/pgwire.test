# name: test/sql/pgwire.test
# description: test pgwire extension
# group: [pgwire]

# Before we load the extension, this will fail
statement error
SELECT * FROM start_pgwire_server('127.0.0.1', 5433);
----
Catalog Error: Table Function with name start_pgwire_server does not exist!

# Require statement will ensure the extension is loaded from now on
require pgwire

# Confirm the extension works
query I
SELECT * FROM pgwire_server_status();
----
No pgwire servers currently running