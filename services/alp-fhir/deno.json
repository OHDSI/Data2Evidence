{
  "compilerOptions": {
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "lib": ["ES2022", "DOM", "deno.ns"]
  },
  "tasks": {
    "start": "deno run --allow-all index.ts",
