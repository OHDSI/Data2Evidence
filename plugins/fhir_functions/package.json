{
  "name": "@data2evidence/fhir",
  "version": "0.0.99",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "tbuild ."
  },
  "author": "",
  "license": "Apache-2.0",
  "devDependencies": {
    "@trex/cli": "latest"
  },
  "trex": {
    "functions": {
      "init": [
      ],
      "api": [
        {
          "source": "/fhir-gateway",
          "function": "/fhir-gateway",
          "env": "fhir-gateway",
          "imports": "/fhir-gateway/deno.json"
        }
      ],
      "env": { 
        "_shared": {},
        "fhir-gateway": {
          "BINARY_UPLOAD_LIMIT_SIZE": "${BINARY_UPLOAD_LIMIT_SIZE:-50mb}",
          "ALP_GATEWAY_OAUTH__URL": "http://${PROJECT_NAME:-d2e}-trex.${TLS__INTERNAL__DOMAIN:-alp.local}:33001/oauth/token",
          "IDP__ALP_DATA_CLIENT_ID": "${LOGTO__D2E_DATA__CLIENT_ID}",
          "IDP__ALP_DATA__CLIENT_SECRET": "${LOGTO__D2E_DATA__CLIENT_SECRET}"
        }
      },
      "roles": {
        "ALP_SYSTEM_ADMIN": [
          "gateway.fhir.create",
          "gateway.fhir.delete",
          "gateway.fhir.forward",
          "gateway.fhir.get"
        ],
        "IDP_ALP_DATA_CLIENT_ID": [
          "gateway.fhir.create",
          "portal.dataset.read",
          "gateway.fhir.forward",
          "gateway.fhir.get",
          "trex"
        ]
      },
      "scopes": [
        {
          "path": "^/fhir-gateway/healthcheck",
          "scopes": [
            "gateway.fhir.forward"
          ],
          "httpMethods": [
            "GET"
          ]
        },
        {
          "path": "^/fhir-gateway/datasets/list",
          "scopes": [
            "gateway.fhir.get"
          ],
          "httpMethods": [
            "GET"
          ]
        },
        {
          "path": "^/fhir-gateway/createDataset$",
          "scopes": [
            "gateway.fhir.create"
          ],
          "httpMethods": [
            "POST"
          ]
        },
        {
          "path": "^/fhir-gateway/deleteDataset/[a-zA-Z0-9_-]+$",
          "scopes": [
            "gateway.fhir.delete"
          ],
          "httpMethods": [
            "DELETE"
          ]
        },
        {
          "path": "^/system-portal/dataset/list/systemadmin$",
          "scopes": [
            "portal.dataset.read"
          ],
          "httpMethods": [
            "GET"
          ]
        },
        {
          "path": "^/fhir-gateway/dataset/[a-zA-Z0-9_-]+/(.*)",
          "scopes": [
            "gateway.fhir.forward"
          ],
          "httpMethods": [
            "POST",
            "GET",
            "PUT",
            "PATCH",
            "DELETE"
          ]
        },
        {
          "path": "^/fhir-gateway/dataset/[a-zA-Z0-9_-]+$",
          "scopes": [
            "gateway.fhir.forward"
          ],
          "httpMethods": [
            "POST"
          ]
        }
      ]
    }
  }
}
