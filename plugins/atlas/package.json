{
  "name": "@data2evidence/atlas",
  "version": "0.0.1",
  "description": "Atlas3 UI plugin for Trex",
  "type": "module",
  "license": "Apache-2.0",
  "scripts": {
    "postinstall": "node scripts/postinstall.js",
    "build": "vite build && vite build --config vite.portal.config.mjs",
    "build:cohorts": "vite build",
    "build:portal": "vite build --config vite.portal.config.mjs",
    "dev": "vite"
  },
  "dependencies": {
    "@d4l/web-components-library": "^3.0.0",
    "@ohdsi/atlas3": "^0.1.0-20260125122024-57e9209",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "single-spa-react": "^6.0.0",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "single-spa-vue": "^3.0.0",
    "systemjs": "^6.15.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vue-router": "^4.2.0",
    "vue-tsc": "^1.8.0"
  },
  "trex": {
    "ui": {
      "routes": [
        {
          "source": "/atlas",
          "target": "/resources/atlas"
        },
        {
          "source": "/atlas-portal",
          "target": "/resources/portal"
        }
      ],
      "uiplugins": {
        "researcher": [
          {
            "name": "Atlas",
            "nameI18nKey": "UI_PLUGIN_ATLAS",
            "route": "atlas",
            "pluginPath": "/atlas-portal/index.js",
            "type": "app",
            "autoMount": false,
            "enabled": true,
            "requiredRoles": [
              "RESEARCHER"
            ]
          }
        ]
      }
    }
  }
}
