{
  "name": "@data2evidence/atlas",
  "version": "0.0.1",
  "description": "OHDSI Atlas3 UI plugin for Trex (served at /atlas, connected to WebAPI via d2e)",
  "type": "module",
  "license": "Apache-2.0",
  "files": [
    "resources"
  ],
  "scripts": {
    "postinstall": "node scripts/postinstall.js",
    "build": "vite build && vite build --config vite.portal.config.mjs",
    "build:cohorts": "vite build",
    "build:portal": "vite build --config vite.portal.config.mjs",
    "dev": "vite"
  },
  "dependencies": {
    "@ohdsi/atlas3": "0.1.0-20260621142339-0a13950",
    "@ohdsi/jobs-plugin": "^0.1.0",
    "@ohdsi/network-plugin": "^0.1.0",
    "@ohdsi/notebook-plugin": "^0.1.0",
    "@ohdsi/pythia-plugin": "0.1.0-develop.2.g8edf28a",
    "@ohdsi/results-viewer": "^0.2.0",
    "@ohdsi/strategus-plugin": "^0.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "single-spa-react": "^6.0.0",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "single-spa-vue": "^3.0.0",
    "systemjs": "^6.15.0",
    "typescript": "^5.3.0",
    "vite": "^6.4.2",
    "vue-router": "^4.2.0",
    "vue-tsc": "^1.8.0"
  },
  "trex": {
    "ui": {
      "routes": [
        {
          "source": "/atlas",
          "target": "/resources/atlas"
        },
        {
          "source": "/atlas-portal",
          "target": "/resources/portal"
        },
        {
          "source": "/atlas-login",
          "target": "/resources/login"
        }
      ],
      "uiplugins": {
        "researcher": [
          {
            "name": "Atlas",
            "nameI18nKey": "UI_PLUGIN_ATLAS",
            "route": "atlas",
            "pluginPath": "/atlas-portal/index.js",
            "type": "app",
            "autoMount": false,
            "enabled": true,
            "requiredRoles": [
              "RESEARCHER"
            ]
          }
        ]
      }
    }
  }
}
