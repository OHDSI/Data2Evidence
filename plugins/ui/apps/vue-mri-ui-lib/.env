VITE_PATH=
VITE_NAVIGATION_ITEMS=[{"id":"concept-sets","title":"Concepts","route":"/concepts","appName":"concept-sets","importUrl":"/resources/concept-sets/lifecycles.js","autoMount":true},{"id":"analysis-ui","title":"Analysis","route":"/analysis","appName":"analysis-ui","importUrl":"/resources/analysis-ui/lifecycles.js"},{"id":"notebook-ui","title":"Notebook","route":"/notebook","appName":"notebook-ui","importUrl":"/resources/notebook-ui/lifecycles.js","customProps":{"uiFilesUrl":"https://localhost:41100/"}}]

#################################
# Local Development Configuration
# These values are injected at build time
# Changes to these values require restart of dev server
#################################
# Toggle behavior between standalone Atlas mode and D2E integrated mode. Also controls the vue server's proxied request url
VITE_STANDALONE_ATLAS=false
# From main d2e .env LOGTO__D2E_APP__CLIENT_ID
VITE_CLIENT_ID=
# Find the dataset id uuid
VITE_DATASET_ID=
# Enable debug mode to see Vue warnings and errors (default: false)
VITE_DEBUG=false
# Feature flags as JSON array
VITE_FEATURES=[{"feature": "adminOnlySharing", "isEnabled": false}, {"feature": "wizards", "isEnabled": true}]
