{
  "name": "@data2evidence/mimic-omop-conversion-flow",
  "version": "0.0.99",
  "description": "",
  "scripts": {
      "build": "docker build ../ -f ./Dockerfile -t d2e/flow-mimic-omop-conversion:local --build-arg GITHUB_PAT=${GITHUB_PAT} --platform=linux/amd64"
  },
  "repository": {
      "type": "git",
      "url": "https://github.com/OHDSI/d2e.git"
  },
  "author": "",
  "license": "Apache-2.0",
  "bugs": {
      "url": "https://github.com/OHDSI/d2e/issues"
  },
  "homepage": "https://github.com/OHDSI/d2e/flows#readme",
  "trex": {
      "flow": {
          "image": "ghcr.io/ohdsi/d2e/flow-mimic-omop-conversion",
          "flows": [
              {
                  "name": "mimic_omop_conversion_plugin",
                  "entrypoint": "flows.mimic_omop_conversion_plugin.flow.mimic_omop_conversion_plugin",
                  "parameter_openapi_schema": {
                    "type": "object",
                    "title": "Parameters",
                    "required": ["options"],
                    "properties": {
                        "options": {
                            "$ref": "#/definitions/MimicOMOPOptionsType",
                            "title": "options",
                            "position": 0
                        }
                    },
                    "definitions": {
                        "FlowActionType": {
                            "enum": [
                                "mimic_to_database",
                                "mimic_to_duckdb",
                                "duckdb_to_database"
                            ],
                            "type": "string",
                            "title": "FlowActionType"
                        },
                        "MimicOMOPOptionsType": {
                            "type": "object",
                            "title": "MimicOMOPOptionsType",
                            "required": ["flow_action_type"],
                            "properties": {
                                "mimic_dir": {
                                    "type": "string",
                                    "title": "Mimic Dir",
                                    "default": "/app/mimic_omop/mimic"
                                },
                                "vocab_dir": {
                                    "type": "string",
                                    "title": "Vocab Dir",
                                    "default": "/app/mimic_omop/vocab"
                                },
                                "chunk_size": {
                                    "type": "integer",
                                    "title": "Chunk Size",
                                    "default": 5000
                                },
                                "schema_name": {
                                    "anyOf": [
                                        {"type": "string"},
                                        {"type": "null"}
                                    ],
                                    "title": "Schema Name",
                                    "default": null
                                },
                                "database_code": {
                                    "anyOf": [
                                        {"type": "string"},
                                        {"type": "null"}
                                    ],
                                    "title": "Database Code",
                                    "default": null
                                },
                                "duckdb_file_path": {
                                    "type": "string",
                                    "title": "Duckdb File Path",
                                    "default": 
            "/app/mimic_omop/mimic/mimic_omop_duckdb"
                                },
                                "flow_action_type": {
                                    "$ref": "#/definitions/FlowActionType"
                                },
                                "load_mimic_vocab": {
                                    "type": "boolean",
                                    "title": "Load Mimic Vocab",
                                    "default": true
                                },
                                "overwrite_schema": {
                                    "type": "boolean",
                                    "title": "Overwrite Schema",
                                    "default": false
                                }
                            }
                        }
                    }
                },
                  "type": "mimic"
              }
          ]
      }
  }
}