                                  },
                                  "headers": {
                                      "title": "Headers",
                                      "type": "object"
                                  },
                                  "data": {
                                      "title": "Data",
                                      "type": "object"
                                  }
                              },
                              "required": [
                                  "headers",
                                  "data"
                              ],
                              "title": "PerseusRequestType",
                              "type": "object"
                          }
                      }
                  },
                  "type": "perseus"
              }
          ]
      }
  }
