  "bugs": {
    "url": "https://github.com/data2evidence/d2e-flows/issues"
  },
  "homepage": "https://github.com/data2evidence/d2e-flows#readme",
  "trex": {
    "flow": {
      "image": "ghcr.io/data2evidence/d2e/flow-white-rabbit",
      "flows": [
        {
          "name": "white_rabbit_plugin",
          "type": "white_rabbit",
          "entrypoint": "flows.white_rabbit_plugin.flow.white_rabbit_plugin",
          "image": "ghcr.io/data2evidence/d2e/flow-white-rabbit:develop",
          "image_pull_policy": "Never",
          "tags": [
            "white_rabbit"
          ],
          "parameter_openapi_schema": {
            "title": "Parameters",
            "type": "object",
            "properties": {
              "options": {
                "$ref": "#/definitions/WhiteRabbitRequestType",
                "position": 0,
                "title": "options"
              }
            },
            "required": [
              "options"
            ],
            "definitions": {
              "WhiteRabbitRunType": {
                "enum": [
                    "SCAN_REPORT_FILES",
                    "SCAN_REPORT_DB",
                    "GENERATE_ETL_REPORT"
                  ],
                  "title": "WhiteRabbitRunType",
                  "type": "string"
              },
              "WhiteRabbitRequestType": {
                "properties": {
                  "run_type": {
                    "$ref": "#/definitions/WhiteRabbitRunType"
                  },
                  "data": {
                    "title": "Data",
                    "type": "object"
                  },
                  "database_code": {
                      "default": "",
                      "title": "Database Code",
                      "type": "string"
                    }
                },
                "required": [
                  "run_type",
                  "data"
                ],
                "title": "WhiteRabbitRequestType",
                "type": "object"
              }
            }
          }
        }
      ]
    }
  }
