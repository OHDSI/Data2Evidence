                                  },
                                  "datasets": {
                                      "anyOf": [
                                          {
                                              "items": {},
                                              "type": "array"
                                          },
                                          {
                                              "type": "null"
                                          }
                                      ],
                                      "default": null,
                                      "title": "Datasets"
                                  }
                              },
                              "required": [
                                  "flow_action_type"
                              ],
                              "title": "i2b2PluginType",
                              "type": "object"
                          }
                      }
                  },
                  "type": "datamodel",
                  "datamodels": [
                      "v1.8.1"
                  ]
              }
          ]
