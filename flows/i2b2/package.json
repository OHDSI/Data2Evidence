                              "title": "FlowActionType",
                              "type": "string"
                          },
                          "i2b2PluginType": {
                              "properties": {
                                  "flow_action_type": {
                                      "$ref": "#/definitions/FlowActionType"
                                  },
                                  "database_code": {
                                      "default": "",
                                      "title": "Database Code",
                                      "type": "string"
                                  },
                                  "schema_name": {
                                      "anyOf": [
                                          {
                                              "type": "string"
                                          },
                                          {
                                              "type": "null"
                                          }
                                      ],
                                      "default": null,
                                      "title": "Schema Name"
                                  },
                                  "data_model": {
                                      "anyOf": [
                                          {
                                              "type": "string"
                                          },
                                          {
                                              "type": "null"
                                          }
                                      ],
                                      "default": null,
                                      "title": "Data Model"
                                  },
                                  "load_demo_data": {
                                      "anyOf": [
                                          {
                                              "type": "boolean"
                                          },
                                          {
                                              "type": "null"
                                          }
