{
  "name": "demo-notifications",
  "version": "1.0.0",
  "scripts": {
    "start": "vite",
    "dev": "concurrently --kill-others \"bun build:watch\" \"bun preview\"",
    "build": "vite build",
    "build:dev": "vite build --mode=development",
    "build:watch": "vite build --mode=development --watch",
    "preview": "vite preview --mode=development"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "single-spa": "^6.0.3",
    "single-spa-react": "^6.0.2"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-basic-ssl": "^1.1.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.2.1",
    "typescript": "^5.2.2",
    "vite": "^5.3.1",
    "vite-plugin-css-injected-by-js": "^3.5.1"
  }
}
