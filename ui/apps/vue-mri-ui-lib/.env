#################################
# Local Development Configuration
# These values are injected at build time
# Changes to these values require restart of dev server
#################################
# Toggle behavior between standalone Atlas mode and D2E integrated mode. Also controls the vue server's proxied request url
VUE_APP_STANDALONE_ATLAS=false
# From main d2e .env LOGTO__ALP_APP__CLIENT_ID
VUE_APP_CLIENT_ID=
# Find the dataset id uuid
VUE_APP_DATASET_ID=
# Enable debug mode to see Vue warnings and errors (default: false)
VUE_APP_DEBUG=false
