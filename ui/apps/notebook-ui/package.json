{
  "name": "notebook-ui",
  "version": "1.0.0",
  "scripts": {
    "start": "vite",
    "dev": "concurrently --kill-others \"bun build:watch\" \"bun preview\"",
    "build": "vite build",
    "build:dev": "vite build --mode=development",
    "build:watch": "vite build --mode=development --watch",
    "preview": "vite preview --mode=development",
    "lint": "eslint src --ext js,ts,tsx",
    "format": "prettier --write .",
    "check-format": "prettier --check ."
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@types/systemjs": "^6.1.1",
    "@vitejs/plugin-basic-ssl": "^1.1.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.2.1",
    "eslint": "^8.57.0",
    "typescript": "^5.2.2",
    "vite": "^5.3.1",
    "vite-plugin-css-injected-by-js": "^3.5.1"
  },
  "dependencies": {
    "@data2evidence/d2e-starboard-wrap": "https://github.com/data2evidence/d2e-starboard-wrap.git#develop",
    "@emotion/react": "^11.9.0",
    "@emotion/styled": "^11.8.1",
    "@mui/icons-material": "^5.8.3",
    "@mui/material": "^5.8.3",
    "@nlux/react": "^2.17.1",
    "@nlux/themes": "^2.17.1",
    "@portal/components": "^1.0.0",
    "axios": "^0.27.2",
    "file-saver": "^2.0.5",
    "i18next": "^23.7.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^14.0.0",
    "react-toastify": "^9.1.3",
    "single-spa": "^6.0.0",
    "single-spa-react": "^6.0.2"
  }
}
