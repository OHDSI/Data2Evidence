<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core">
    <Dialog title="{i18n>MRI_PA_CFG_WIZARDS_CONFIG_DIALOG_TITLE}" contentWidth="60rem" contentHeight="30rem" resizable="true" draggable="true" stretchOnPhone="true">
        <content>
            <VBox fitContainer="true" renderType="Bare">
                <Text text="{i18n>MRI_PA_CFG_WIZARDS_CONFIG_DIALOG_DESCRIPTION}" />
                <TextArea rows="16" width="100%" value="{wizardsEditorModel>/jsonText}" valueLiveUpdate="true" liveChange="onWizardsJsonLiveChange" valueState="{wizardsEditorModel>/valueState}" />
                <Text text="{wizardsEditorModel>/errorText}" visible="{= !!${wizardsEditorModel>/errorText}}" />
            </VBox>
        </content>
        <beginButton>
            <Button text="{i18n>MRI_PA_CFG_BUTTON_SAVE}" press="onSaveWizardsConfig" />
        </beginButton>
        <endButton>
            <Button text="{i18n>MRI_PA_CFG_BUTTON_CANCEL}" press="onCancelWizardsConfig" />
        </endButton>
    </Dialog>
</core:FragmentDefinition>
