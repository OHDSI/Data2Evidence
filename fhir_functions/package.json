{
  "name": "@data2evidence/fhir",
  "version": "0.0.99",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "tbuild node_modules/@data2evidence/trex"
  },
  "author": "",
  "license": "Apache-2.0",
  "devDependencies": {
    "@data2evidence/trex": "latest",
    "deno": "latest"
  },
  "trex": {
    "functions": {
      "init": [
        {
          "function": "/alp-fhir-init/src",
          "imports": "/alp-fhir-init/src/deno.json",
          "env": "alp-fhir-init",
          "waitforEnvVar": "FHIR_SERVER_HEALTHCHECK"
        }
      ],
      "api": [
        {
          "source": "/gateway/api/fhir",
          "function": "/alp-fhir-svc",
          "env": "alp-fhir-svc",
          "imports": "/alp-fhir-svc/deno.json"
        }
      ],
      "roles": {
        "ALP_SYSTEM_ADMIN": [
          "gateway.fhir.create",
          "gateway.fhir.delete"
        ],
        "IDP_ALP_DATA_CLIENT_ID": [
          "gateway.fhir.create",
          "portal.dataset.read",
          "fhir.server.config.get"
        ]
      },
      "scopes": [
        {
          "path": "^/gateway/api/fhir/createProject",
          "scopes": [
            "gateway.fhir.create"
          ],
          "httpMethods": [
            "POST"
          ]
        },
        {
          "path": "^/gateway/api/fhir/project/[a-zA-Z0-9_]+/(?!Project|ProjectMembership|ClientApplication|User|Login|PasswordChangeRequest|JsonWebKey|Bot|AccessPolicy|UserConfiguration|BulkDataExport|SmartAppLaunch|DomainConfiguration|AsyncJob|Agent|IdentityProvider|UserSecurityRequest|ViewDefinition)(.*)",
          "scopes": [
            "gateway.fhir.create"
          ],
          "httpMethods": [
            "POST",
            "GET",
            "PUT",
            "PATCH",
            "DELETE"
          ]
        },
        {
          "path": "^/gateway/api/fhir/deleteProject",
          "scopes": [
            "gateway.fhir.delete"
          ],
          "httpMethods": [
            "DELETE"
          ]
        },
        {
          "path": "^/gateway/api/fhir/test",
          "scopes": [
            "gateway.fhir.create"
          ],
          "httpMethods": [
            "GET"
          ]
        }
      ]
    }
  }
}
