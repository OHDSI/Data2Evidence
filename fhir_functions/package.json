{
  "name": "@data2evidence/fhir",
  "version": "0.0.99",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "tbuild ."
  },
  "author": "",
  "license": "Apache-2.0",
  "devDependencies": {
    "@trex/cli": "latest"
  },
  "trex": {
    "functions": {
      "init": [
        {
          "function": "/alp-fhir-gateway-init",
          "imports": "/alp-fhir-gateway-init/deno.json",
          "env": "alp-fhir-gateway-init"
        }
      ],
      "api": [
        {
          "source": "/fhir-gateway",
          "function": "/alp-fhir-gateway",
          "env": "alp-fhir-gateway",
          "imports": "/alp-fhir-gateway/deno.json"
        }
      ],
      "env": { 
        "_shared": {},
        "alp-fhir-gateway": {
          "FHIR__LOG_LEVEL": "debug",
          "FHIR__CLIENT_ID": "${FHIR__CLIENT_ID:-${FHIR__CLIENT_ID:-db6b2304-f236-45ec-b10c-a852681e7129}}",
          "FHIR__CLIENT_SECRET": "${FHIR__CLIENT_SECRET}",
          "BINARY_UPLOAD_LIMIT_SIZE": "${BINARY_UPLOAD_LIMIT_SIZE:-50mb}"
        },
         "alp-fhir-gateway-init":{
          "FHIR_DATABASE_CODE": "${FHIR__DATABASE__CODE:-d2e_fhir}",
          "PG__HOST": "${PG_HOST:-${PROJECT_NAME:-d2e}-minerva-postgres-1}",
          "PG__MAX_POOL": "${PG__MAX_POOL:-10}",
          "PG__PORT": "${PG_PORT:-5432}",
          "PG__IDLE_TIMEOUT_IN_MS": "${PG__IDLE_TIMEOUT_IN_MS:-1000}",
          "PG_DB_NAME": "${PG_DB_NAME:-alp}",
          "PG_ADMIN_PASSWORD": "${PG_ADMIN_PASSWORD}",
          "PG_ADMIN_USER": "${PG_ADMIN_USER:-alp_pg_admin_user}",
          "FHIR_CUSTOM_SCHEMA": "${FHIR_CUSTOM_SCHEMA:-fhir}",
          "DB_CREDENTIALS__PUBLIC_KEYS": "${DB_CREDENTIALS__PUBLIC_KEYS}",
          "ALP_GATEWAY_OAUTH__URL": "http://${PROJECT_NAME:-d2e}-trex.${TLS__INTERNAL__DOMAIN:-alp.local}:33001/oauth/token",
          "IDP__ALP_DATA_CLIENT_ID": "${LOGTO__ALP_DATA__CLIENT_ID}",
          "LOGTO__ALP_DATA__CLIENT_SECRET": "${LOGTO__ALP_DATA__CLIENT_SECRET}"
        }
      },
      "roles": {
        "ALP_SYSTEM_ADMIN": [
          "gateway.fhir.create",
          "gateway.fhir.delete",
          "gateway.fhir.forward",
          "gateway.fhir.get"
        ],
        "IDP_ALP_DATA_CLIENT_ID": [
          "gateway.fhir.create",
          "portal.dataset.read",
          "gateway.fhir.forward",
          "gateway.fhir.get",
          "trex"
        ]
      },
      "scopes": [
        {
          "path": "^/fhir-gateway/check-readiness",
          "scopes": [
            "gateway.fhir.get"
          ],
          "httpMethods": [
            "GET"
          ]
        },
        {
          "path": "^/fhir-gateway/fhir-server/healthcheck",
          "scopes": [
            "gateway.fhir.forward"
          ],
          "httpMethods": [
            "GET"
          ]
        },
        {
          "path": "^/fhir-gateway/createProject",
          "scopes": [
            "gateway.fhir.create"
          ],
          "httpMethods": [
            "POST"
          ]
        },
        {
          "path": "^/fhir-gateway/project/[a-zA-Z0-9_]+/(?!Project|ProjectMembership|ClientApplication|User|Login|PasswordChangeRequest|JsonWebKey|Bot|AccessPolicy|UserConfiguration|BulkDataExport|SmartAppLaunch|DomainConfiguration|AsyncJob|Agent|IdentityProvider|UserSecurityRequest|ViewDefinition)(.*)",
          "scopes": [
            "gateway.fhir.forward"
          ],
          "httpMethods": [
            "POST",
            "GET",
            "PUT",
            "PATCH",
            "DELETE"
          ]
        },
        {
          "path": "^/fhir-gateway/deleteProject",
          "scopes": [
            "gateway.fhir.delete"
          ],
          "httpMethods": [
            "DELETE"
          ]
        },
        {
          "path": "^/system-portal/dataset/list/systemadmin$",
          "scopes": [
            "portal.dataset.read"
          ],
          "httpMethods": [
            "GET"
          ]
        }
      ]
    }
  }
}
